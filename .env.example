# ---------------------------------------------------------------------------
# Home Assistant connection
# ---------------------------------------------------------------------------
# Two ways to connect:
#   1. Direct      — set HA_URL + HA_TOKEN below.
#   2. Brokered    — leave HA_TOKEN empty and set VOMEHOME_TOKEN +
#                    VOMEHOME_INSTANCE_ID (see the VomeHome section). The agent
#                    never holds an HA token; reads/writes are policed + audited
#                    server-side, so the policy can't be bypassed.
#
# Base URL of your Home Assistant instance, no trailing slash (direct mode).
HA_URL=http://homeassistant.local:8123
# Long-lived access token (direct mode).
# Create one in Home Assistant: Profile -> Security -> Long-lived access tokens.
HA_TOKEN=

# ---------------------------------------------------------------------------
# Write safety (defaults are deliberately cautious)
# ---------------------------------------------------------------------------
# Master switch. While false, every state-changing tool is refused.
HA_ALLOW_WRITE=false
# Domains that may NEVER be written, even when HA_ALLOW_WRITE=true.
# Comma-separated. Set to an empty value to clear the list entirely.
HA_DENY_DOMAINS=lock,alarm_control_panel,cover,climate,vacuum,valve,water_heater,lawn_mower,camera
# Optional allow-list. When non-empty, ONLY these domains may be written
# (the deny-list still applies on top).
HA_ALLOW_DOMAINS=
# Allow editing automation/script/scene config via the config API.
# Requires HA_ALLOW_WRITE=true as well.
HA_ALLOW_CONFIG_WRITE=false

# ---------------------------------------------------------------------------
# ESPHome Dashboard (optional)
# ---------------------------------------------------------------------------
# Base URL of the ESPHome Dashboard (add-on or standalone), no trailing slash.
ESPHOME_DASHBOARD_URL=
# Auth for the dashboard if it is protected. Use a bearer token...
ESPHOME_DASHBOARD_TOKEN=
# ...or HTTP basic auth.
ESPHOME_DASHBOARD_USERNAME=
ESPHOME_DASHBOARD_PASSWORD=

# ---------------------------------------------------------------------------
# Node-RED (optional — flow-based automation editor)
# ---------------------------------------------------------------------------
# Base URL of the Node-RED editor/admin API, no trailing slash. The HA add-on
# typically exposes it on port 1880, e.g. http://homeassistant.local:1880.
NODERED_URL=
# Auth for the admin API if adminAuth is enabled. Either a bearer access token...
NODERED_TOKEN=
# ...or a username/password (the client exchanges these for a token via
# /auth/token). Leave all three empty for an unsecured admin API (trusted
# network or behind an auth-terminating proxy / ingress).
NODERED_USERNAME=
NODERED_PASSWORD=

# ---------------------------------------------------------------------------
# VomeHome portal (optional — managed Home Assistant hosting)
# ---------------------------------------------------------------------------
# Enables the vomehome_* tools (list / status / reboot / create / login URL).
# Base URL of the VomeHome portal, no trailing slash.
VOMEHOME_API_URL=https://vome.io
# Personal access token. Log in to the portal with GitHub, then create one under
# Account -> API tokens, and paste it here. VomeHome tools stay disabled until set.
# Tip: a read-only token (the default) lets an agent inspect but never change.
VOMEHOME_TOKEN=
# Instance (server) id for BROKERED Home Assistant access. When set together
# with VOMEHOME_TOKEN and an empty HA_TOKEN, all HA tools route through the
# VomeHome portal — the HA credential stays server-side and never reaches the
# agent. Find your id via the vomehome_list_instances tool or the dashboard.
VOMEHOME_INSTANCE_ID=
# Extra guard for the heavyweight "create instance" action. Even with
# HA_ALLOW_WRITE=true, creating a VM additionally requires this to be true.
VOMEHOME_ALLOW_CREATE=false

# ---------------------------------------------------------------------------
# Misc
# ---------------------------------------------------------------------------
# HTTP request timeout in milliseconds.
HA_TIMEOUT_MS=15000
# Maximum number of items a list tool will return before truncating.
MAX_RESULTS=500
# Log level: error | warn | info | debug
LOG_LEVEL=info
