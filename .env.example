# ---------------------------------------------------------------------------
# Home Assistant connection
# ---------------------------------------------------------------------------
# Two ways to connect:
#   1. Direct      — set HA_URL + HA_TOKEN below.
#   2. Brokered    — leave HA_TOKEN empty and set VOMEHOME_TOKEN +
#                    VOMEHOME_INSTANCE_ID (and optionally VOMEHOME_INSTANCES for
#                    several servers — see the VomeHome section). The agent never
#                    holds an HA token; reads/writes are policed + audited
#                    server-side, so the policy can't be bypassed.
#
# Base URL of your Home Assistant instance, no trailing slash (direct mode).
HA_URL=http://homeassistant.local:8123
# Long-lived access token (direct mode).
# Create one in Home Assistant: Profile -> Security -> Long-lived access tokens.
HA_TOKEN=

# ---------------------------------------------------------------------------
# Write safety
# ---------------------------------------------------------------------------
# Who decides what a write may do depends on the mode:
#   * DIRECT mode (HA_TOKEN set) — the MCP is the ONLY guard, so these default
#     OFF and you must opt in to writes here.
#   * BROKERED mode (VomeHome) — permissions live on your API key and are
#     enforced server-side PER INSTANCE (read / write / config / create), so
#     these become OPTIONAL local-only restrictions and default permissive
#     (the server has the final say and returns 403 if the key lacks a scope).
#
# Master switch for state-changing tools. Empty -> off in direct mode,
# permissive in brokered mode. Set false to add a local block on top.
HA_ALLOW_WRITE=
# Domains that may NEVER be written, even when writes are allowed.
# Comma-separated. Set to an empty value to clear the list entirely.
HA_DENY_DOMAINS=lock,alarm_control_panel,cover,climate,vacuum,valve,water_heater,lawn_mower,camera
# Optional allow-list. When non-empty, ONLY these domains may be written
# (the deny-list still applies on top).
HA_ALLOW_DOMAINS=
# Allow editing automation/script/scene config via the config API.
# Same default semantics as HA_ALLOW_WRITE above.
HA_ALLOW_CONFIG_WRITE=

# ---------------------------------------------------------------------------
# ESPHome Dashboard (optional)
# ---------------------------------------------------------------------------
# Base URL of the ESPHome Dashboard (add-on or standalone), no trailing slash.
ESPHOME_DASHBOARD_URL=
# Auth for the dashboard if it is protected. Use a bearer token...
ESPHOME_DASHBOARD_TOKEN=
# ...or HTTP basic auth.
ESPHOME_DASHBOARD_USERNAME=
ESPHOME_DASHBOARD_PASSWORD=

# ---------------------------------------------------------------------------
# Node-RED (optional — flow-based automation editor)
# ---------------------------------------------------------------------------
# Base URL of the Node-RED editor/admin API, no trailing slash. The HA add-on
# typically exposes it on port 1880, e.g. http://homeassistant.local:1880.
NODERED_URL=
# Auth for the admin API if adminAuth is enabled. Either a bearer access token...
NODERED_TOKEN=
# ...or a username/password (the client exchanges these for a token via
# /auth/token). Leave all three empty for an unsecured admin API (trusted
# network or behind an auth-terminating proxy / ingress).
NODERED_USERNAME=
NODERED_PASSWORD=

# ---------------------------------------------------------------------------
# VomeHome portal (optional — managed Home Assistant hosting)
# ---------------------------------------------------------------------------
# Enables the vomehome_* tools (list / status / reboot / create / login URL).
# Base URL of the VomeHome portal, no trailing slash.
VOMEHOME_API_URL=https://vome.io
# Personal access token — this is the SINGLE source of truth for permissions.
# Log in to the portal with GitHub, then create one under Account -> API tokens.
# You set what it may do there, per instance (read / write / config) plus the
# account-wide create scope, and you can edit those after issuing the key. The
# MCP just carries the token; the server enforces. VomeHome tools stay disabled
# until this is set.
VOMEHOME_TOKEN=
# The ACTIVE/DEFAULT instance (server) id for BROKERED Home Assistant access.
# When set together with VOMEHOME_TOKEN and an empty HA_TOKEN, all HA tools route
# through the VomeHome portal — the HA credential stays server-side and never
# reaches the agent. Find your id via vomehome_list_instances or the dashboard.
# What it may do is decided by your token's scopes for THIS instance (set in the
# portal). Switch the active instance at runtime with vomehome_use_instance.
VOMEHOME_INSTANCE_ID=
#
# OPTIONAL: declare MULTIPLE instances so they are known at startup (e.g. to keep
# access to one you created earlier). VOMEHOME_INSTANCES is JSON: an array of
# objects (or ids), or an object keyed by id. The server still decides what the
# token may do per instance; the per-instance "write"/"config" here are only
# extra LOCAL restrictions, and omitting them defaults permissive in brokered
# mode (let the server decide). Set false to belt-and-braces block locally.
#   VOMEHOME_INSTANCES=[{"id":"rly-house","label":"home"},{"id":"sbx-plc","write":false,"label":"PLC sandbox (local read-only)"}]
# The default instance (VOMEHOME_INSTANCE_ID) is folded in automatically if it is
# not listed here.
VOMEHOME_INSTANCES=
# OPTIONAL local guard for the heavyweight "create instance" action. The real
# authority is the account-wide create scope on your API key (set in the portal);
# leave empty to defer to it, or set false to block creation locally regardless.
# Instances you create via the MCP become the active target and are usable for
# the session; add the new id to VOMEHOME_INSTANCES to keep it across restarts.
VOMEHOME_ALLOW_CREATE=

# ---------------------------------------------------------------------------
# Misc
# ---------------------------------------------------------------------------
# HTTP request timeout in milliseconds.
HA_TIMEOUT_MS=15000
# Maximum number of items a list tool will return before truncating.
MAX_RESULTS=500
# Log level: error | warn | info | debug
LOG_LEVEL=info
