# ---------------------------------------------------------------------------
# Home Assistant connection (required)
# ---------------------------------------------------------------------------
# Base URL of your Home Assistant instance, no trailing slash.
HA_URL=http://homeassistant.local:8123
# Long-lived access token.
# Create one in Home Assistant: Profile -> Security -> Long-lived access tokens.
HA_TOKEN=

# ---------------------------------------------------------------------------
# Write safety (defaults are deliberately cautious)
# ---------------------------------------------------------------------------
# Master switch. While false, every state-changing tool is refused.
HA_ALLOW_WRITE=false
# Domains that may NEVER be written, even when HA_ALLOW_WRITE=true.
# Comma-separated. Set to an empty value to clear the list entirely.
HA_DENY_DOMAINS=lock,alarm_control_panel,cover,climate,vacuum,valve,water_heater,lawn_mower,camera
# Optional allow-list. When non-empty, ONLY these domains may be written
# (the deny-list still applies on top).
HA_ALLOW_DOMAINS=
# Allow editing automation/script/scene config via the config API.
# Requires HA_ALLOW_WRITE=true as well.
HA_ALLOW_CONFIG_WRITE=false

# ---------------------------------------------------------------------------
# ESPHome Dashboard (optional)
# ---------------------------------------------------------------------------
# Base URL of the ESPHome Dashboard (add-on or standalone), no trailing slash.
ESPHOME_DASHBOARD_URL=
# Auth for the dashboard if it is protected. Use a bearer token...
ESPHOME_DASHBOARD_TOKEN=
# ...or HTTP basic auth.
ESPHOME_DASHBOARD_USERNAME=
ESPHOME_DASHBOARD_PASSWORD=

# ---------------------------------------------------------------------------
# Misc
# ---------------------------------------------------------------------------
# HTTP request timeout in milliseconds.
HA_TIMEOUT_MS=15000
# Maximum number of items a list tool will return before truncating.
MAX_RESULTS=500
# Log level: error | warn | info | debug
LOG_LEVEL=info
