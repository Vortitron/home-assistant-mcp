{
	"name": "@vortitron/home-assistant-mcp",
	"version": "0.3.0",
	"description": "Model Context Protocol (MCP) server that lets coding agents (Cursor, VS Code, Claude) read and control Home Assistant and ESPHome: inspect entities, call services, render templates, debug logs and edit automations.",
	"type": "module",
	"license": "MIT",
	"author": "Vortitron",
	"homepage": "https://github.com/Vortitron/home-assistant-mcp#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Vortitron/home-assistant-mcp.git"
	},
	"bugs": {
		"url": "https://github.com/Vortitron/home-assistant-mcp/issues"
	},
	"bin": {
		"home-assistant-mcp": "dist/index.js"
	},
	"main": "dist/index.js",
	"exports": {
		".": "./dist/index.js"
	},
	"publishConfig": {
		"access": "public"
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE",
		".env.example"
	],
	"engines": {
		"node": ">=18.18"
	},
	"scripts": {
		"build": "tsc -p tsconfig.json",
		"prepare": "npm run build",
		"dev": "tsx watch src/index.ts",
		"start": "node dist/index.js",
		"doctor": "tsx src/index.ts doctor",
		"typecheck": "tsc -p tsconfig.json --noEmit",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"keywords": [
		"mcp",
		"model-context-protocol",
		"home-assistant",
		"homeassistant",
		"esphome",
		"cursor",
		"vscode",
		"claude",
		"ai",
		"agent",
		"llm",
		"home-automation",
		"smart-home",
		"iot"
	],
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.29.0",
		"dotenv": "^16.4.7",
		"ws": "^8.18.0",
		"zod": "^3.25.76"
	},
	"devDependencies": {
		"@eslint/js": "^9.34.0",
		"@types/node": "^22.10.0",
		"@types/ws": "^8.5.13",
		"eslint": "^9.34.0",
		"tsx": "^4.19.2",
		"typescript": "^5.7.0",
		"typescript-eslint": "^8.20.0",
		"vitest": "^2.1.0"
	}
}
